{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ilxyr.dev/schemas/sandbox-run.v1.json",
  "title": "ilxyr sandbox run v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "id", "sandbox_id", "experiment_id", "budget_id", "executable", "args",
    "cost_credits",
    "started_at_ms", "completed_at_ms", "exit_code", "timed_out",
    "stdout", "stderr", "output_truncated", "metrics", "authority", "previous_event"
  ],
  "properties": {
    "schema": { "const": "ilxyr.sandbox_run.v1" },
    "id": { "type": "string", "pattern": "^[A-Za-z0-9._:/-]+$" },
    "sandbox_id": { "type": "string", "pattern": "^[A-Za-z0-9._:/-]+$" },
    "experiment_id": { "type": "string", "pattern": "^[A-Za-z0-9._:/-]+$" },
    "budget_id": { "type": "string", "pattern": "^[A-Za-z0-9._:/-]+$" },
    "executable": {
      "type": "string",
      "pattern": "^/",
      "description": "Absolute path. Must be on the epoch allowlist."
    },
    "args": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[^\\u0000]*$" }
    },
    "cost_credits": { "type": "integer", "minimum": 1 },
    "started_at_ms": { "type": "integer", "minimum": 0 },
    "completed_at_ms": { "type": "integer", "minimum": 0 },
    "exit_code": { "type": "integer" },
    "timed_out": { "type": "boolean" },
    "stdout": { "type": "string" },
    "stderr": { "type": "string" },
    "output_truncated": { "type": "boolean" },
    "output_error": { "type": "string", "minLength": 1 },
    "metrics": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "scope", "provenance"],
      "properties": {
        "level": {
          "enum": ["exact_check", "deterministic_replay", "corpus_proxy", "review"]
        },
        "scope": {
          "type": "object",
          "additionalProperties": false,
          "required": ["seeds"],
          "properties": {
            "seeds": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "type": "integer", "minimum": 0 }
            },
            "eval_set": { "type": "string", "pattern": "^(dataset|artifact)://\\S+$" },
            "coverage": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "provenance": {
          "type": "object",
          "additionalProperties": false,
          "required": ["artifact_hashes", "checker"],
          "properties": {
            "artifact_hashes": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "type": "string", "pattern": "^artifact://sha256/[a-f0-9]{64}$" }
            },
            "model_lineage": { "type": "string", "pattern": "^model://\\S+$" },
            "checker": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "previous_event": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "Hash of the preceding ledger event."
    }
  }
}
