{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ilxyr.dev/schemas/shared-task.v1.json",
  "title": "ilxyr shared task contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "id", "title", "dataset", "eval_set", "metrics", "seeds", "family_bindings"],
  "properties": {
    "schema": { "const": "ilxyr.shared_task.v1" },
    "id": { "$ref": "#/$defs/identifier" },
    "title": { "type": "string", "minLength": 1 },
    "dataset": { "$ref": "#/$defs/artifactBinding" },
    "eval_set": { "$ref": "#/$defs/artifactBinding" },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/metric" }
    },
    "seeds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "integer", "minimum": 0 }
    },
    "family_bindings": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "$ref": "#/$defs/familyBinding" },
      "allOf": [
        {
          "contains": {
            "type": "object",
            "required": ["family"],
            "properties": { "family": { "const": "zero" } }
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "required": ["family"],
            "properties": { "family": { "const": "solomon" } }
          },
          "minContains": 1,
          "maxContains": 1
        }
      ]
    }
  },
  "$defs": {
    "identifier": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9._:/-]+$" },
    "artifactBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["handle", "sha256"],
      "properties": {
        "handle": { "type": "string", "pattern": "^dataset://\\S+$" },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "unit", "description"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "unit": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "familyBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["family", "encoding", "verifier", "designated_proposer"],
      "properties": {
        "family": { "enum": ["zero", "solomon"] },
        "encoding": { "type": "string", "minLength": 1 },
        "verifier": { "type": "string", "minLength": 1 },
        "designated_proposer": { "$ref": "#/$defs/actor" }
      }
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["human", "model", "service"] },
        "model_ref": { "type": "string", "pattern": "^model://\\S+$" }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "model" } } },
          "then": {
            "properties": { "id": { "type": "string", "pattern": "^model://" }, "model_ref": true },
            "required": ["model_ref"]
          }
        },
        {
          "if": { "properties": { "kind": { "const": "human" } } },
          "then": { "properties": { "id": { "type": "string", "pattern": "^human://" }, "model_ref": false } }
        },
        {
          "if": { "properties": { "kind": { "const": "service" } } },
          "then": { "properties": { "id": { "type": "string", "pattern": "^service://" }, "model_ref": false } }
        }
      ]
    }
  }
}
