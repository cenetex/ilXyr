{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ilxyr.dev/schemas/certificate.v1.json",
  "title": "ilxyr certificate v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "id", "evidence_ref", "predicate", "domain", "checker",
    "checked_artifacts", "issued_at_ms"
  ],
  "properties": {
    "schema": { "const": "ilxyr.certificate.v1" },
    "id": { "type": "string", "pattern": "^[A-Za-z0-9._:/-]+$" },
    "evidence_ref": {
      "type": "string",
      "pattern": "^artifact://sha256/[a-f0-9]{64}$",
      "description": "The evidence object this certificate attests to."
    },
    "predicate": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "metric", "operator", "threshold"],
          "properties": {
            "kind": { "const": "metric" },
            "metric": { "type": "string", "minLength": 1 },
            "operator": { "enum": ["gt", "gte", "lt", "lte", "eq"] },
            "threshold": { "type": "number" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": { "kind": { "const": "execution_failure" } }
        }
      ]
    },
    "domain": {
      "description": "The exact finite or decidable domain over which the predicate was checked.",
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "values"],
          "properties": {
            "kind": { "const": "enumerated" },
            "values": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": true
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "fragment", "declaration"],
          "properties": {
            "kind": { "const": "decidable_fragment" },
            "fragment": { "type": "string", "minLength": 1 },
            "declaration": { "type": "string", "minLength": 1 }
          }
        }
      ]
    },
    "checker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "checked_artifacts": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^artifact://sha256/[a-f0-9]{64}$"
      }
    },
    "issued_at_ms": { "type": "integer", "minimum": 0 }
  }
}
