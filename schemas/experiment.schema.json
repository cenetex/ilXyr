{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ilxyr.dev/schemas/experiment.v1.json",
  "title": "ilxyr experiment specification v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "id", "title", "hypothesis", "rationale", "proposer", "lineage",
    "baseline", "datasets", "models", "metrics", "seeds", "outcome_contract",
    "execution", "funding", "security", "evidence_authority", "expected_outputs"
  ],
  "properties": {
    "schema": { "const": "ilxyr.experiment.v1" },
    "id": { "$ref": "#/$defs/identifier" },
    "title": { "type": "string", "minLength": 1 },
    "hypothesis": { "type": "string", "minLength": 1 },
    "rationale": { "type": "string", "minLength": 1 },
    "proposer": { "$ref": "#/$defs/actor" },
    "family": { "enum": ["zero", "solomon"] },
    "shared_task_id": { "$ref": "#/$defs/identifier" },
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hypothesis", "mathematical_foundation", "engineering_review", "experiment_design"
      ],
      "properties": {
        "hypothesis": { "$ref": "#/$defs/identifier" },
        "mathematical_foundation": { "$ref": "#/$defs/identifier" },
        "engineering_review": { "$ref": "#/$defs/identifier" },
        "experiment_design": { "$ref": "#/$defs/identifier" }
      }
    },
    "baseline": { "$ref": "#/$defs/handle" },
    "datasets": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^dataset://\\S+$" }
    },
    "models": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^weight://\\S+$" }
    },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "unit", "description"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "unit": { "type": "string" },
          "description": { "type": "string", "minLength": 1 }
        }
      }
    },
    "seeds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "integer", "minimum": 0 }
    },
    "outcome_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary_metric", "success_outcome", "outcomes"],
      "properties": {
        "primary_metric": { "type": "string", "minLength": 1 },
        "success_outcome": { "$ref": "#/$defs/identifier" },
        "outcomes": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/outcome" }
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["executor", "program", "args", "timeout_seconds", "max_cost_credits", "network"],
      "properties": {
        "executor": { "type": "string", "minLength": 1 },
        "program": { "type": "string", "minLength": 1 },
        "args": { "type": "array", "items": { "type": "string" } },
        "timeout_seconds": { "type": "integer", "minimum": 1 },
        "max_cost_credits": { "type": "integer", "minimum": 1 },
        "network": { "enum": ["open", "denied"] }
      }
    },
    "funding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_compute_credits", "minimum_forecasters", "minimum_total_stake"],
      "properties": {
        "required_compute_credits": { "type": "integer", "minimum": 1 },
        "minimum_forecasters": { "type": "integer", "minimum": 1 },
        "minimum_total_stake": { "type": "integer", "minimum": 1 }
      }
    },
    "security": {
      "type": "object",
      "additionalProperties": false,
      "required": ["weight_class", "code_policy", "export_policy"],
      "properties": {
        "weight_class": { "enum": ["public", "internal", "restricted"] },
        "code_policy": { "enum": ["arbitrary", "approved_image_only"] },
        "export_policy": { "enum": ["artifacts", "metrics_only", "none"] }
      }
    },
    "evidence_authority": { "$ref": "#/$defs/authority" },
    "expected_outputs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "identifier": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9._:/-]+$" },
    "handle": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9+.-]*://\\S+$",
      "not": { "pattern": "^file://" }
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["human", "model", "service"] },
        "model_ref": { "type": "string", "pattern": "^model://\\S+$" }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "model" } } },
          "then": {
            "properties": { "id": { "type": "string", "pattern": "^model://" }, "model_ref": true },
            "required": ["model_ref"]
          }
        },
        {
          "if": { "properties": { "kind": { "const": "human" } } },
          "then": { "properties": { "id": { "type": "string", "pattern": "^human://" }, "model_ref": false } }
        },
        {
          "if": { "properties": { "kind": { "const": "service" } } },
          "then": { "properties": { "id": { "type": "string", "pattern": "^service://" }, "model_ref": false } }
        }
      ]
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "scope", "provenance"],
      "properties": {
        "level": {
          "enum": ["exact_check", "deterministic_replay", "corpus_proxy", "review"]
        },
        "scope": {
          "type": "object",
          "additionalProperties": false,
          "required": ["seeds"],
          "properties": {
            "seeds": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "type": "integer", "minimum": 0 }
            },
            "eval_set": { "type": "string", "pattern": "^(dataset|artifact)://\\S+$" },
            "coverage": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "provenance": {
          "type": "object",
          "additionalProperties": false,
          "required": ["artifact_hashes", "checker"],
          "properties": {
            "artifact_hashes": {
              "type": "array",
              "uniqueItems": true,
              "items": { "type": "string", "pattern": "^artifact://sha256/[a-f0-9]{64}$" }
            },
            "model_lineage": { "type": "string", "pattern": "^model://\\S+$" },
            "checker": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description", "predicate"],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "description": { "type": "string", "minLength": 1 },
        "predicate": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind", "metric", "operator", "threshold"],
              "properties": {
                "kind": { "const": "metric" },
                "metric": { "type": "string", "minLength": 1 },
                "operator": { "enum": ["gt", "gte", "lt", "lte"] },
                "threshold": { "type": "number" }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind"],
              "properties": { "kind": { "const": "execution_failure" } }
            }
          ]
        }
      }
    }
  }
}
